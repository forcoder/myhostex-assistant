#!/bin/sh
#
# MyHostex 智能回复助手 - pre-commit hook
# 提交前自动运行回归测试，全部通过才能提交。
#
# 安装方式：
#   ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit
#   或
#   cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#

echo ""
echo "═══════════════════════════════════════"
echo "   🔍 运行回归测试..."
echo "═══════════════════════════════════════"

cd "$(git rev-parse --show-toplevel)"

node tests/regression-test.js
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ 回归测试未通过（${EXIT_CODE}），提交已阻止！"
  echo "   请先修复问题，然后重新提交。"
  echo "   如需跳过测试: git commit --no-verify"
  echo ""
  exit 1
fi

echo ""
echo "✅ 回归测试全部通过，提交继续。"
echo ""
exit 0
